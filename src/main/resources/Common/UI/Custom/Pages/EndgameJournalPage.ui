$C = "../Common.ui";

// ========== STYLES ==========

@TabStyle = TextButtonStyle(
  Default: (Background: #0b141f, LabelStyle: (FontSize: 13, TextColor: #5a6a7a, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #141e2a, LabelStyle: (FontSize: 13, TextColor: #c0cee5, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #0b141f, LabelStyle: (FontSize: 13, TextColor: #5a6a7a, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Sounds: $C.@ButtonSounds
);
@TabActiveStyle = TextButtonStyle(
  Default: (Background: #1a2a3a, LabelStyle: (FontSize: 13, TextColor: #f4f9ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #1a2a3a, LabelStyle: (FontSize: 13, TextColor: #f4f9ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #162230, LabelStyle: (FontSize: 13, TextColor: #c0cee5, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Sounds: $C.@ButtonSounds
);

@ClaimBtnStyle = TextButtonStyle(
  Default: (Background: #1a3d2e, LabelStyle: (FontSize: 11, TextColor: #4aff7f, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #2a4d3e, LabelStyle: (FontSize: 11, TextColor: #6aff9f, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #0a2d1e, LabelStyle: (FontSize: 11, TextColor: #4aff7f, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Sounds: $C.@ButtonSounds
);

@FilterBtnStyle = TextButtonStyle(
  Default: (Background: #0f1a24, LabelStyle: (FontSize: 10, TextColor: #5a6a7a, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #1a2a3a, LabelStyle: (FontSize: 10, TextColor: #f4f9ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #0b141f, LabelStyle: (FontSize: 10, TextColor: #c0cee5, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Sounds: $C.@ButtonSounds
);
@FilterActiveBtnStyle = TextButtonStyle(
  Default: (Background: #1a2a3a, LabelStyle: (FontSize: 10, TextColor: #f4f9ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #243444, LabelStyle: (FontSize: 10, TextColor: #f4f9ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #1a2a3a, LabelStyle: (FontSize: 10, TextColor: #c0cee5, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Sounds: $C.@ButtonSounds
);

@DiffBadgeStyle = (FontSize: 9, TextColor: #55ff55, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);

@NavBtnStyle = TextButtonStyle(
  Default: (Background: #141e2a, LabelStyle: (FontSize: 13, TextColor: #5a6a7a, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #1e2a36, LabelStyle: (FontSize: 13, TextColor: #f4f9ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #0b141f, LabelStyle: (FontSize: 13, TextColor: #5a6a7a, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Sounds: $C.@ButtonSounds
);

@LabelStyle = (FontSize: 14, TextColor: #f4f9ff, RenderBold: true, VerticalAlignment: Center);
@SubLabelStyle = (FontSize: 12, TextColor: #c0cee5, VerticalAlignment: Center);
@SmallLabel = (FontSize: 11, TextColor: #7a8d9e, VerticalAlignment: Center);

$C.@PageOverlay {
  $C.@DecoratedContainer {
    Anchor: (Width: 920, Height: 700);

    #Title {
      Group {
        $C.@Title {
          @Text = "Journal";
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 0);

      // ======== TAB BAR ========
      Group #TabBar {
        LayoutMode: Left;
        Anchor: (Height: 38);
        Padding: (Left: 4, Right: 4, Top: 3);

        $C.@TextButton #TabBounty { FlexWeight: 1; Anchor: (Height: 32); Text: "Bounty Board"; Style: @TabActiveStyle; }
        Group { Anchor: (Width: 4); }
        $C.@TextButton #TabBestiary { FlexWeight: 1; Anchor: (Height: 32); Text: "Bestiary"; Style: @TabStyle; }
        Group { Anchor: (Width: 4); }
        $C.@TextButton #TabAchievements { FlexWeight: 1; Anchor: (Height: 32); Text: "Achievements"; Style: @TabStyle; }
      }
      Group { Anchor: (Height: 2); Background: #1a2a3a; }

      // ==================== BOUNTY TAB ====================
      Group #ContentBounty {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Padding: (Full: 16);
        Visible: true;

        // ---- RANK HEADER (prominent) ----
        Group {
          LayoutMode: Top;
          Background: #0b141f(0.9);
          Padding: (Full: 0);
          Anchor: (Bottom: 14);

          // Gold accent top line
          Group { Anchor: (Height: 3); Background: #FFD700; }
          // Content with padding
          Group { LayoutMode: Top; Padding: (Full: 14);
            // Rank name large
            Group { LayoutMode: Left; Anchor: (Height: 30);
              Label #BountyRank { Style: (FontSize: 20, TextColor: #FFD700, RenderBold: true, VerticalAlignment: Center); Anchor: (Width: 200); Text: "NOVICE"; }
              Group { FlexWeight: 1; }
              Label #BountyRefresh { Style: (FontSize: 10, TextColor: #5a6a7a, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 160); Text: "Refresh: --"; }
            }
            Group { Anchor: (Height: 8); }
            // Rep progress bar (wide, visible)
            Group #BountyHeader {
              LayoutMode: Left;
              Anchor: (Height: 22);

              Group #BountyRepBg { FlexWeight: 1; Anchor: (Height: 12); Background: #0a0f14;
                Group #BountyRepFill { Anchor: (Width: 0, Height: 12, Left: 0, Top: 0); Background: #FFD700; }
              }
              Group { Anchor: (Width: 10); }
              Label #BountyRepText { Style: (FontSize: 11, TextColor: #c0cee5, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 80); Text: "0/500"; }
            }
          }
        }

        // ---- BOUNTY CARDS ----

        // Bounty 0
        Group #Bounty0 { LayoutMode: Left; Anchor: (Bottom: 10); Background: #0b141f(0.88); Padding: (Full: 0); Visible: false;
          // Left accent strip
          Group #Bounty0Accent { Anchor: (Width: 4, Height: 120); Background: #4aff7f; }
          // Card content
          Group { LayoutMode: Top; FlexWeight: 1; Padding: (Full: 12);
            Group { LayoutMode: Left; Anchor: (Height: 22);
              Label #Bounty0Diff { Style: @DiffBadgeStyle; Anchor: (Width: 60, Height: 20); Background: #1a3d2e; Text: "EASY"; }
              Group { Anchor: (Width: 10); }
              Label #Bounty0Desc { Style: (FontSize: 13, TextColor: #f4f9ff, VerticalAlignment: Center); FlexWeight: 1; Text: ""; }
            }
            Group { Anchor: (Height: 6); }
            Group { LayoutMode: Left; Anchor: (Height: 14);
              Group #Bounty0BarBg { FlexWeight: 1; Anchor: (Height: 10); Background: #0a0f14;
                Group #Bounty0BarFill { Anchor: (Width: 0, Height: 10, Left: 0, Top: 0); Background: #4aff7f; }
              }
              Group { Anchor: (Width: 8); }
              Label #Bounty0Prog { Style: (FontSize: 10, TextColor: #7a8d9e, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 80); Text: "0 / 0"; }
            }
            Group { Anchor: (Height: 4); }
            Label #Bounty0Reward { Style: (FontSize: 10, TextColor: #c0cee5); Anchor: (Height: 16); Text: ""; }
            Label #Bounty0Bonus { Style: (FontSize: 9, TextColor: #5a6a7a); Anchor: (Height: 14); Text: ""; Visible: false; }
            Group { LayoutMode: Left; Anchor: (Height: 26); Padding: (Top: 4);
              Label #Bounty0Status { Style: (FontSize: 11, TextColor: #5a6a7a, RenderBold: true, VerticalAlignment: Center); FlexWeight: 1; Text: ""; }
              TextButton #Bounty0Claim { Anchor: (Width: 110, Height: 24); Text: "Claim"; Style: @ClaimBtnStyle; Visible: false; }
            }
          }
        }

        // Bounty 1
        Group #Bounty1 { LayoutMode: Left; Anchor: (Bottom: 10); Background: #0b141f(0.88); Padding: (Full: 0); Visible: false;
          Group #Bounty1Accent { Anchor: (Width: 4, Height: 120); Background: #ffcc44; }
          Group { LayoutMode: Top; FlexWeight: 1; Padding: (Full: 12);
            Group { LayoutMode: Left; Anchor: (Height: 22);
              Label #Bounty1Diff { Style: @DiffBadgeStyle; Anchor: (Width: 60, Height: 20); Background: #3d3d1a; Text: "MEDIUM"; }
              Group { Anchor: (Width: 10); }
              Label #Bounty1Desc { Style: (FontSize: 13, TextColor: #f4f9ff, VerticalAlignment: Center); FlexWeight: 1; Text: ""; }
            }
            Group { Anchor: (Height: 6); }
            Group { LayoutMode: Left; Anchor: (Height: 14);
              Group #Bounty1BarBg { FlexWeight: 1; Anchor: (Height: 10); Background: #0a0f14;
                Group #Bounty1BarFill { Anchor: (Width: 0, Height: 10, Left: 0, Top: 0); Background: #ffcc44; }
              }
              Group { Anchor: (Width: 8); }
              Label #Bounty1Prog { Style: (FontSize: 10, TextColor: #7a8d9e, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 80); Text: "0 / 0"; }
            }
            Group { Anchor: (Height: 4); }
            Label #Bounty1Reward { Style: (FontSize: 10, TextColor: #c0cee5); Anchor: (Height: 16); Text: ""; }
            Label #Bounty1Bonus { Style: (FontSize: 9, TextColor: #5a6a7a); Anchor: (Height: 14); Text: ""; Visible: false; }
            Group { LayoutMode: Left; Anchor: (Height: 26); Padding: (Top: 4);
              Label #Bounty1Status { Style: (FontSize: 11, TextColor: #5a6a7a, RenderBold: true, VerticalAlignment: Center); FlexWeight: 1; Text: ""; }
              TextButton #Bounty1Claim { Anchor: (Width: 110, Height: 24); Text: "Claim"; Style: @ClaimBtnStyle; Visible: false; }
            }
          }
        }

        // Bounty 2
        Group #Bounty2 { LayoutMode: Left; Anchor: (Bottom: 10); Background: #0b141f(0.88); Padding: (Full: 0); Visible: false;
          Group #Bounty2Accent { Anchor: (Width: 4, Height: 120); Background: #ff5555; }
          Group { LayoutMode: Top; FlexWeight: 1; Padding: (Full: 12);
            Group { LayoutMode: Left; Anchor: (Height: 22);
              Label #Bounty2Diff { Style: @DiffBadgeStyle; Anchor: (Width: 60, Height: 20); Background: #3d1a1a; Text: "HARD"; }
              Group { Anchor: (Width: 10); }
              Label #Bounty2Desc { Style: (FontSize: 13, TextColor: #f4f9ff, VerticalAlignment: Center); FlexWeight: 1; Text: ""; }
            }
            Group { Anchor: (Height: 6); }
            Group { LayoutMode: Left; Anchor: (Height: 14);
              Group #Bounty2BarBg { FlexWeight: 1; Anchor: (Height: 10); Background: #0a0f14;
                Group #Bounty2BarFill { Anchor: (Width: 0, Height: 10, Left: 0, Top: 0); Background: #ff5555; }
              }
              Group { Anchor: (Width: 8); }
              Label #Bounty2Prog { Style: (FontSize: 10, TextColor: #7a8d9e, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 80); Text: "0 / 0"; }
            }
            Group { Anchor: (Height: 4); }
            Label #Bounty2Reward { Style: (FontSize: 10, TextColor: #c0cee5); Anchor: (Height: 16); Text: ""; }
            Label #Bounty2Bonus { Style: (FontSize: 9, TextColor: #5a6a7a); Anchor: (Height: 14); Text: ""; Visible: false; }
            Group { LayoutMode: Left; Anchor: (Height: 26); Padding: (Top: 4);
              Label #Bounty2Status { Style: (FontSize: 11, TextColor: #5a6a7a, RenderBold: true, VerticalAlignment: Center); FlexWeight: 1; Text: ""; }
              TextButton #Bounty2Claim { Anchor: (Width: 110, Height: 24); Text: "Claim"; Style: @ClaimBtnStyle; Visible: false; }
            }
          }
        }

        // ---- STREAK ----
        Group #StreakSection { LayoutMode: Top; Background: #0b141f(0.84); Padding: (Full: 12); Anchor: (Bottom: 8); Visible: false;
          Group { LayoutMode: Left; Anchor: (Height: 18);
            Group #StreakPip0 { Anchor: (Width: 14, Height: 14); Background: #1a2a3a; }
            Group { Anchor: (Width: 8); }
            Group #StreakPip1 { Anchor: (Width: 14, Height: 14); Background: #1a2a3a; }
            Group { Anchor: (Width: 8); }
            Group #StreakPip2 { Anchor: (Width: 14, Height: 14); Background: #1a2a3a; }
          }
          Group { Anchor: (Height: 4); }
          Label #StreakText { Style: (FontSize: 12, TextColor: #FFD700, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Height: 22); Text: "Complete all 3 bounties for a streak bonus"; }
          Group { Anchor: (Height: 4); }
          TextButton #StreakClaim { Anchor: (Width: 150, Height: 26); Text: "Claim Streak"; Style: @ClaimBtnStyle; Visible: false; }
        }

        // ---- WEEKLY ----
        Group #WeeklyDivider { Anchor: (Height: 1); Background: #bb88ff; Visible: false; }
        Group #WeeklySpacer { Anchor: (Height: 8); Visible: false; }

        Group #WeeklyBounty { LayoutMode: Left; Anchor: (Bottom: 10); Background: #0b141f(0.88); Padding: (Full: 0); Visible: false;
          Group { Anchor: (Width: 4, Height: 120); Background: #bb88ff; }
          Group { LayoutMode: Top; FlexWeight: 1; Padding: (Full: 12);
            Group { LayoutMode: Left; Anchor: (Height: 22);
              Label #WeeklyDiff { Style: (FontSize: 9, TextColor: #bb88ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 60, Height: 20); Background: #2a1a3d; Text: "WEEKLY"; }
              Group { Anchor: (Width: 10); }
              Label #WeeklyDesc { Style: (FontSize: 13, TextColor: #f4f9ff, VerticalAlignment: Center); FlexWeight: 1; Text: ""; }
            }
            Group { Anchor: (Height: 6); }
            Group { LayoutMode: Left; Anchor: (Height: 14);
              Group #WeeklyBarBg { FlexWeight: 1; Anchor: (Height: 10); Background: #0a0f14;
                Group #WeeklyBarFill { Anchor: (Width: 0, Height: 10, Left: 0, Top: 0); Background: #bb88ff; }
              }
              Group { Anchor: (Width: 8); }
              Label #WeeklyProg { Style: (FontSize: 10, TextColor: #7a8d9e, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 80); Text: "0 / 0"; }
            }
            Group { Anchor: (Height: 4); }
            Label #WeeklyReward { Style: (FontSize: 10, TextColor: #c0cee5); Anchor: (Height: 16); Text: ""; }
            Group { LayoutMode: Left; Anchor: (Height: 26); Padding: (Top: 4);
              Label #WeeklyStatus { Style: (FontSize: 11, TextColor: #5a6a7a, RenderBold: true, VerticalAlignment: Center); FlexWeight: 1; Text: ""; }
              TextButton #WeeklyClaim { Anchor: (Width: 110, Height: 24); Text: "Claim"; Style: @ClaimBtnStyle; Visible: false; }
            }
          }
        }
      }

      // ==================== BESTIARY TAB ====================
      Group #ContentBestiary {
        FlexWeight: 1;
        LayoutMode: Top;
        Padding: (Full: 14);
        Visible: false;

        // Stats
        Label #BestiaryStats { Style: (FontSize: 11, TextColor: #7a8d9e, HorizontalAlignment: Center); Anchor: (Height: 18); Text: "0 / 0 Discovered | 0 Total Kills"; }
        Group { Anchor: (Height: 6); }

        // Discovery milestones
        Group #DiscRow {
          LayoutMode: Left;
          Anchor: (Height: 28);

          Label { Style: (FontSize: 10, TextColor: #5a6a7a, VerticalAlignment: Center); Anchor: (Width: 70, Height: 24); Text: "Discover:"; }
          TextButton #Disc0 { Anchor: (Width: 56, Height: 24); Text: "5"; Style: @FilterBtnStyle; }
          Group { Anchor: (Width: 3); }
          TextButton #Disc1 { Anchor: (Width: 56, Height: 24); Text: "10"; Style: @FilterBtnStyle; }
          Group { Anchor: (Width: 3); }
          TextButton #Disc2 { Anchor: (Width: 56, Height: 24); Text: "15"; Style: @FilterBtnStyle; }
          Group { Anchor: (Width: 3); }
          TextButton #Disc3 { Anchor: (Width: 56, Height: 24); Text: "20"; Style: @FilterBtnStyle; }
          Group { Anchor: (Width: 3); }
          TextButton #Disc4 { Anchor: (Width: 56, Height: 24); Text: "25"; Style: @FilterBtnStyle; }
          Group { Anchor: (Width: 3); }
          TextButton #Disc5 { Anchor: (Width: 56, Height: 24); Text: "ALL"; Style: @FilterBtnStyle; }
        }
        Group { Anchor: (Height: 1); Background: #1a2a3a; }
        Group { Anchor: (Height: 6); }

        // Category filters
        Group #FilterRow {
          LayoutMode: Left;
          Anchor: (Height: 28);

          TextButton #FilterAll { Anchor: (Width: 108, Height: 24); Text: "ALL"; Style: @FilterActiveBtnStyle; }
          Group { Anchor: (Width: 3); }
          TextButton #FilterBoss { Anchor: (Width: 108, Height: 24); Text: "BOSS"; Style: @FilterBtnStyle; }
          Group { Anchor: (Width: 3); }
          TextButton #FilterElite { Anchor: (Width: 108, Height: 24); Text: "ELITE"; Style: @FilterBtnStyle; }
          Group { Anchor: (Width: 3); }
          TextButton #FilterElemental { Anchor: (Width: 108, Height: 24); Text: "ELEMENTAL"; Style: @FilterBtnStyle; }
          Group { Anchor: (Width: 3); }
          TextButton #FilterCreature { Anchor: (Width: 108, Height: 24); Text: "CREATURE"; Style: @FilterBtnStyle; }
          Group { Anchor: (Width: 3); }
          TextButton #FilterEndgame { Anchor: (Width: 108, Height: 24); Text: "ENDGAME"; Style: @FilterBtnStyle; }
          Group { Anchor: (Width: 3); }
          TextButton #FilterSpecial { Anchor: (Width: 108, Height: 24); Text: "SPECIAL"; Style: @FilterBtnStyle; }
        }
        Group { Anchor: (Height: 6); }

        // Empty state
        Label #BestiaryEmpty { Style: (FontSize: 13, TextColor: #5a6a7a, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Height: 40); Text: "No creatures found."; Visible: false; }

        // Mob cards
        Group #MobList {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;

          // Mob Card 0
          Group #Mob0 { LayoutMode: Left; Anchor: (Bottom: 8); Background: #0b141f(0.88); Padding: (Full: 10); Visible: false;
            Group { Anchor: (Width: 68, Height: 68); Background: #0a0f14;
              AssetImage #Mob0Portrait { Anchor: (Width: 64, Height: 64); AssetPath: ""; }
            }
            Group { Anchor: (Width: 10); }
            Group { LayoutMode: Top; FlexWeight: 1;
              Group { LayoutMode: Left; Anchor: (Height: 20);
                Label #Mob0Cat { Style: (FontSize: 9, TextColor: #ff5555, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 75, Height: 18); Background: #3d1a1a; Text: ""; }
                Group { Anchor: (Width: 8); }
                Label #Mob0Name { Style: (FontSize: 13, TextColor: #f4f9ff, RenderBold: true, VerticalAlignment: Center); FlexWeight: 1; Text: "???"; }
                Label #Mob0HP { Style: (FontSize: 12, TextColor: #ff5555, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 90); Text: ""; }
              }
              Group { Anchor: (Height: 2); }
              Group { LayoutMode: Left; Anchor: (Height: 16);
                Label #Mob0Dmg { Style: (FontSize: 11, TextColor: #ff8800, VerticalAlignment: Center); FlexWeight: 1; Text: ""; }
                Label #Mob0Loc { Style: (FontSize: 11, TextColor: #4a9eff, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 160); Text: ""; }
              }
              Label #Mob0DescText { Style: (FontSize: 10, TextColor: #7a8d9e, Wrap: true); Anchor: (Height: 16); Text: ""; }
              Label #Mob0Drops { Style: (FontSize: 10, TextColor: #FFD700); Anchor: (Height: 14); Text: ""; Visible: false; }
              Label #Mob0Kills { Style: (FontSize: 9, TextColor: #5a6a7a); Anchor: (Height: 14); Text: ""; Visible: false; }
              Group #Mob0Miles { LayoutMode: Left; Anchor: (Height: 22); Visible: false;
                Label { Style: (FontSize: 9, TextColor: #5a6a7a, VerticalAlignment: Center); Anchor: (Width: 60, Height: 20); Text: "Milestones:"; }
                TextButton #Mob0Ms0 { Anchor: (Width: 44, Height: 20); Text: ""; Style: @FilterBtnStyle; Visible: false; }
                Group { Anchor: (Width: 3); }
                TextButton #Mob0Ms1 { Anchor: (Width: 44, Height: 20); Text: ""; Style: @FilterBtnStyle; Visible: false; }
                Group { Anchor: (Width: 3); }
                TextButton #Mob0Ms2 { Anchor: (Width: 44, Height: 20); Text: ""; Style: @FilterBtnStyle; Visible: false; }
                Group { Anchor: (Width: 3); }
                TextButton #Mob0Ms3 { Anchor: (Width: 44, Height: 20); Text: ""; Style: @FilterBtnStyle; Visible: false; }
              }
            }
          }

          // Mob Card 1-9 (same structure)
          Group #Mob1 { LayoutMode: Left; Anchor: (Bottom: 8); Background: #0b141f(0.88); Padding: (Full: 10); Visible: false; Group { Anchor: (Width: 68, Height: 68); Background: #0a0f14; AssetImage #Mob1Portrait { Anchor: (Width: 64, Height: 64); AssetPath: ""; } } Group { Anchor: (Width: 10); } Group { LayoutMode: Top; FlexWeight: 1; Group { LayoutMode: Left; Anchor: (Height: 20); Label #Mob1Cat { Style: (FontSize: 9, TextColor: #ff5555, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 75, Height: 18); Background: #3d1a1a; Text: ""; } Group { Anchor: (Width: 8); } Label #Mob1Name { Style: (FontSize: 13, TextColor: #f4f9ff, RenderBold: true, VerticalAlignment: Center); FlexWeight: 1; Text: "???"; } Label #Mob1HP { Style: (FontSize: 12, TextColor: #ff5555, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 90); Text: ""; } } Group { Anchor: (Height: 2); } Group { LayoutMode: Left; Anchor: (Height: 16); Label #Mob1Dmg { Style: (FontSize: 11, TextColor: #ff8800, VerticalAlignment: Center); FlexWeight: 1; Text: ""; } Label #Mob1Loc { Style: (FontSize: 11, TextColor: #4a9eff, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 160); Text: ""; } } Label #Mob1DescText { Style: (FontSize: 10, TextColor: #7a8d9e, Wrap: true); Anchor: (Height: 16); Text: ""; } Label #Mob1Drops { Style: (FontSize: 10, TextColor: #FFD700); Anchor: (Height: 14); Text: ""; Visible: false; } Label #Mob1Kills { Style: (FontSize: 9, TextColor: #5a6a7a); Anchor: (Height: 14); Text: ""; Visible: false; } Group #Mob1Miles { LayoutMode: Left; Anchor: (Height: 22); Visible: false; Label { Style: (FontSize: 9, TextColor: #5a6a7a, VerticalAlignment: Center); Anchor: (Width: 60, Height: 20); Text: "Milestones:"; } TextButton #Mob1Ms0 { Anchor: (Width: 44, Height: 20); Text: ""; Style: @FilterBtnStyle; Visible: false; } Group { Anchor: (Width: 3); } TextButton #Mob1Ms1 { Anchor: (Width: 44, Height: 20); Text: ""; Style: @FilterBtnStyle; Visible: false; } Group { Anchor: (Width: 3); } TextButton #Mob1Ms2 { Anchor: (Width: 44, Height: 20); Text: ""; Style: @FilterBtnStyle; Visible: false; } Group { Anchor: (Width: 3); } TextButton #Mob1Ms3 { Anchor: (Width: 44, Height: 20); Text: ""; Style: @FilterBtnStyle; Visible: false; } } } }

