        // Pagination
        Group #BestiaryNav {
          LayoutMode: Left;
          Anchor: (Height: 34);
          Padding: (Top: 6);

          TextButton #BestiaryPrev { Anchor: (Width: 80, Height: 28); Text: "Prev"; Style: @NavBtnStyle; }
          Group { Anchor: (Width: 8); }
          Label #BestiaryPage { Style: (FontSize: 12, TextColor: #7a8d9e, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 80); Text: "1 / 1"; }
          Group { Anchor: (Width: 8); }
          TextButton #BestiaryNext { Anchor: (Width: 80, Height: 28); Text: "Next"; Style: @NavBtnStyle; }
        }
      }

      // ==================== ACHIEVEMENTS TAB ====================
      Group #ContentAchievements {
        FlexWeight: 1;
        LayoutMode: Top;
        Padding: (Full: 14);
        Visible: false;

        // Stats
        Label #AchStats { Style: (FontSize: 11, TextColor: #7a8d9e, HorizontalAlignment: Center); Anchor: (Height: 18); Text: "0 / 0 completed"; }
        Group { Anchor: (Height: 1); Background: #FFD700; }
        Group { Anchor: (Height: 8); }

        // Achievement cards
        Group #AchList {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;

          // Ach 0
          Group #Ach0 { LayoutMode: Top; Anchor: (Bottom: 8); Background: #0b141f(0.88); Padding: (Full: 12); Visible: false;
            Group { LayoutMode: Left; Anchor: (Height: 22);
              Label #Ach0Name { Style: (FontSize: 13, TextColor: #f4f9ff, RenderBold: true, VerticalAlignment: Center); FlexWeight: 1; Text: ""; }
              Label #Ach0Cat { Style: (FontSize: 9, TextColor: #ff5555, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 90, Height: 20); Background: #3d1a1a; Text: ""; }
            }
            Group { Anchor: (Height: 2); }
            Label #Ach0DescText { Style: (FontSize: 10, TextColor: #7a8d9e); Anchor: (Height: 16); Text: ""; }
            Group { Anchor: (Height: 4); }
            Group { LayoutMode: Left; Anchor: (Height: 14);
              Group #Ach0BarBg { FlexWeight: 1; Anchor: (Height: 10); Background: #0a0f14;
                Group #Ach0BarFill { Anchor: (Width: 0, Height: 10, Left: 0, Top: 0); Background: #4aff7f; }
              }
              Group { Anchor: (Width: 8); }
              Label #Ach0Prog { Style: (FontSize: 10, TextColor: #7a8d9e, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 80); Text: "0 / 0"; }
            }
            Group { Anchor: (Height: 4); }
            Group { LayoutMode: Left; Anchor: (Height: 24);
              Label #Ach0Reward { Style: (FontSize: 10, TextColor: #FFD700, VerticalAlignment: Center); FlexWeight: 1; Text: ""; }
              TextButton #Ach0Claim { Anchor: (Width: 90, Height: 22); Text: "Claim"; Style: @ClaimBtnStyle; Visible: false; }
