      // ==================== ACHIEVEMENTS TAB ====================
      Group #ContentAchievements {
        FlexWeight: 1;
        LayoutMode: Top;
        Padding: (Full: 12);
        Visible: false;

        // Stats line
        Label #AchStats { Style: (FontSize: 11, TextColor: #888888, HorizontalAlignment: Center); Anchor: (Height: 18); Text: "0 / 0 completed"; }
        Group { Anchor: (Height: 2); Background: #FFD700; }
        Group { Anchor: (Height: 6); }

        // Scrollable achievement cards
        Group #AchList {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;

          // Achievement Card 0
          Group #Ach0 { LayoutMode: Top; Anchor: (Bottom: 4); Background: #1a1a2a; Padding: (Full: 8); Visible: false;
