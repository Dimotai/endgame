$C = "../Common.ui";

$C.@PageOverlay {
  $C.@DecoratedContainer {
    Anchor: (Width: 550, Height: 560);

    #Title {
      Group {
        $C.@Title {
          @Text = "The Gauntlet";
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 10);

      // Header
      Label { Style: (FontSize: 20, TextColor: #c084fc, RenderBold: true, HorizontalAlignment: Center); Anchor: (Height: 28); Text: "THE GAUNTLET"; }
      Label { Style: (FontSize: 11, TextColor: #8866aa, HorizontalAlignment: Center); Anchor: (Height: 18); Text: "Leaderboard — Top Survivors"; }
      Group { Anchor: (Height: 2); Background: #c084fc; }
      Group { Anchor: (Height: 6); }

      // Empty message (hidden when entries exist)
      Label #EmptyMsg { Style: (FontSize: 14, TextColor: #555555, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Height: 60); Text: "No challengers yet. Be the first to enter The Gauntlet!"; Visible: true; }

      // Leaderboard rows (10 slots)
      Group #LB0 { LayoutMode: Left; Anchor: (Height: 40, Bottom: 2); Background: #2a2215; Padding: (Horizontal: 12); Visible: false;
        Label #LB0Rank { Style: (FontSize: 18, TextColor: #FFD700, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 50); Text: "1st"; }
        Label #LB0Name { Style: (FontSize: 14, TextColor: #FFD700, RenderBold: true, VerticalAlignment: Center); FlexWeight: 1; Padding: (Left: 8); Text: ""; }
        Label #LB0Wave { Style: (FontSize: 16, TextColor: #FFD700, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 100); Text: ""; }
        Label #LB0Date { Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 60); Text: ""; }
      }
      Group #LB1 { LayoutMode: Left; Anchor: (Height: 40, Bottom: 2); Background: #22222a; Padding: (Horizontal: 12); Visible: false;
        Label #LB1Rank { Style: (FontSize: 18, TextColor: #C0C0C0, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 50); Text: "2nd"; }
        Label #LB1Name { Style: (FontSize: 14, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center); FlexWeight: 1; Padding: (Left: 8); Text: ""; }
        Label #LB1Wave { Style: (FontSize: 16, TextColor: #C0C0C0, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 100); Text: ""; }
        Label #LB1Date { Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 60); Text: ""; }
      }
      Group #LB2 { LayoutMode: Left; Anchor: (Height: 40, Bottom: 2); Background: #22222a; Padding: (Horizontal: 12); Visible: false;
        Label #LB2Rank { Style: (FontSize: 18, TextColor: #CD7F32, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 50); Text: "3rd"; }
        Label #LB2Name { Style: (FontSize: 14, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center); FlexWeight: 1; Padding: (Left: 8); Text: ""; }
        Label #LB2Wave { Style: (FontSize: 16, TextColor: #CD7F32, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 100); Text: ""; }
        Label #LB2Date { Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 60); Text: ""; }
      }
      Group { Anchor: (Height: 1); Background: #2a2a3a; }
      Group #LB3 { LayoutMode: Left; Anchor: (Height: 40, Bottom: 2); Background: #1a1a22; Padding: (Horizontal: 12); Visible: false;
        Label #LB3Rank { Style: (FontSize: 16, TextColor: #666666, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 50); Text: "#4"; }
        Label #LB3Name { Style: (FontSize: 14, TextColor: #ffffff, VerticalAlignment: Center); FlexWeight: 1; Padding: (Left: 8); Text: ""; }
        Label #LB3Wave { Style: (FontSize: 16, TextColor: #c084fc, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 100); Text: ""; }
        Label #LB3Date { Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 60); Text: ""; }
      }
      Group #LB4 { LayoutMode: Left; Anchor: (Height: 40, Bottom: 2); Background: #18182000; Padding: (Horizontal: 12); Visible: false;
        Label #LB4Rank { Style: (FontSize: 16, TextColor: #666666, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 50); Text: "#5"; }
        Label #LB4Name { Style: (FontSize: 14, TextColor: #ffffff, VerticalAlignment: Center); FlexWeight: 1; Padding: (Left: 8); Text: ""; }
        Label #LB4Wave { Style: (FontSize: 16, TextColor: #c084fc, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 100); Text: ""; }
        Label #LB4Date { Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 60); Text: ""; }
      }
      Group #LB5 { LayoutMode: Left; Anchor: (Height: 40, Bottom: 2); Background: #1a1a22; Padding: (Horizontal: 12); Visible: false;
        Label #LB5Rank { Style: (FontSize: 16, TextColor: #666666, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 50); Text: "#6"; }
        Label #LB5Name { Style: (FontSize: 14, TextColor: #ffffff, VerticalAlignment: Center); FlexWeight: 1; Padding: (Left: 8); Text: ""; }
        Label #LB5Wave { Style: (FontSize: 16, TextColor: #c084fc, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 100); Text: ""; }
        Label #LB5Date { Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 60); Text: ""; }
      }
      Group #LB6 { LayoutMode: Left; Anchor: (Height: 40, Bottom: 2); Background: #18182000; Padding: (Horizontal: 12); Visible: false;
        Label #LB6Rank { Style: (FontSize: 16, TextColor: #666666, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 50); Text: "#7"; }
        Label #LB6Name { Style: (FontSize: 14, TextColor: #ffffff, VerticalAlignment: Center); FlexWeight: 1; Padding: (Left: 8); Text: ""; }
        Label #LB6Wave { Style: (FontSize: 16, TextColor: #c084fc, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 100); Text: ""; }
        Label #LB6Date { Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 60); Text: ""; }
      }
      Group #LB7 { LayoutMode: Left; Anchor: (Height: 40, Bottom: 2); Background: #1a1a22; Padding: (Horizontal: 12); Visible: false;
        Label #LB7Rank { Style: (FontSize: 16, TextColor: #666666, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 50); Text: "#8"; }
        Label #LB7Name { Style: (FontSize: 14, TextColor: #ffffff, VerticalAlignment: Center); FlexWeight: 1; Padding: (Left: 8); Text: ""; }
        Label #LB7Wave { Style: (FontSize: 16, TextColor: #c084fc, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 100); Text: ""; }
        Label #LB7Date { Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 60); Text: ""; }
      }
      Group #LB8 { LayoutMode: Left; Anchor: (Height: 40, Bottom: 2); Background: #18182000; Padding: (Horizontal: 12); Visible: false;
        Label #LB8Rank { Style: (FontSize: 16, TextColor: #666666, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 50); Text: "#9"; }
        Label #LB8Name { Style: (FontSize: 14, TextColor: #ffffff, VerticalAlignment: Center); FlexWeight: 1; Padding: (Left: 8); Text: ""; }
        Label #LB8Wave { Style: (FontSize: 16, TextColor: #c084fc, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 100); Text: ""; }
        Label #LB8Date { Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 60); Text: ""; }
      }
      Group #LB9 { LayoutMode: Left; Anchor: (Height: 40, Bottom: 2); Background: #1a1a22; Padding: (Horizontal: 12); Visible: false;
        Label #LB9Rank { Style: (FontSize: 16, TextColor: #666666, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 50); Text: "#10"; }
        Label #LB9Name { Style: (FontSize: 14, TextColor: #ffffff, VerticalAlignment: Center); FlexWeight: 1; Padding: (Left: 8); Text: ""; }
        Label #LB9Wave { Style: (FontSize: 16, TextColor: #c084fc, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 100); Text: ""; }
        Label #LB9Date { Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 60); Text: ""; }
      }

      // Footer
      Label #TotalCount { Style: (FontSize: 10, TextColor: #555555, HorizontalAlignment: Center); Anchor: (Height: 20); Visible: false; Text: ""; }
    }
  }
}

$C.@BackButton {}
