{
  "$Comment": "Jump Slam — wind-up → physics leap forward (Toad_Rhino_Headbutt pattern, single ApplyForce with high Z) → descent with FallFar anim → AOE on impact via WaitForGround/GroundNext.",
  "Type": "Serial",
  "Interactions": [
    {
      "$Comment": "Wind-up: crouch + telegraph rune on ground",
      "Type": "Simple",
      "Effects": {
        "ItemPlayerAnimationsId": "Golem_Void_Default",
        "ItemAnimationId": "GroundSlam",
        "WorldSoundEventId": "SFX_Golem_Earth_Slam_Impact",
        "Particles": [
          {
            "SystemId": "Golem_Void_Telegraph",
            "DetachedFromModel": true,
            "PositionOffset": { "Y": -2.0 },
            "Scale": 5
          }
        ]
      },
      "RunTime": 0.9
    },
    {
      "$Comment": "Launch: strong forward Z with small Y lift — propels the boss forward in a flat arc. Pattern: Toad_Rhino_Headbutt (Y:1, Z:-100, Force:700). AirResistance 0 preserves momentum during flight.",
      "Type": "ApplyForce",
      "Direction": { "Y": 1, "Z": -100 },
      "Force": 600,
      "VelocityConfig": {
        "Threshold": 3,
        "Style": "Linear",
        "AirResistance": 0.05,
        "AirResistanceMax": 0.05,
        "GroundResistance": 0.3,
        "GroundResistanceMax": 0.1
      },
      "ChangeVelocityType": "Add",
      "RunTime": 0.9,
      "Duration": 0.9,
      "Effects": {
        "ItemPlayerAnimationsId": "Golem_Void_Default",
        "ItemAnimationId": "JumpFar"
      }
    },
    {
      "$Comment": "Descent: FallFar anim during the drop + downward nudge + WaitForGround for AOE sync.",
      "Type": "ApplyForce",
      "Direction": { "Y": -1 },
      "Force": 40,
      "VelocityConfig": {
        "Threshold": 5,
        "Style": "Exp",
        "AirResistance": 0
      },
      "Effects": {
        "ItemPlayerAnimationsId": "Golem_Void_Default",
        "ItemAnimationId": "FallFar"
      },
      "WaitForGround": true,
      "GroundNext": {
        "Type": "Selector",
        "RunTime": 0.3,
        "Selector": {
          "Id": "AOECircle",
          "Range": 8
        },
        "Effects": {
          "WorldSoundEventId": "SFX_Golem_Earth_Slam_Impact",
          "Particles": [
            { "SystemId": "Golem_Void_Slam", "Scale": 3 },
            { "SystemId": "Explosion_Big", "Scale": 2 },
            { "SystemId": "Impact_Critical", "Scale": 2 }
          ]
        },
        "HitEntity": {
          "Interactions": [
            "Golem_Void_Jump_Slam_Damage",
            {
              "Type": "ApplyEffect",
              "EffectId": "Endgame_Stagger",
              "Entity": "Target"
            }
          ]
        }
      }
    }
  ]
}
